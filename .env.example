# CRE Investor Discovery MCP — Environment Variables
# Copy to .env and fill in real values before running

# ─── Server ───────────────────────────────────────────────────────────────
PORT=3000

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── PostgreSQL / PostGIS (parcel + entity + portfolio data) ──────────────
DATABASE_URL=postgresql://user:password@localhost:5432/cre_investor

# ─── Layer 2: Entity Resolution ───────────────────────────────────────────
# SOS bulk CSV files — one file per state: {state}_entities.csv
# Required columns: filing_number,name,entity_type,status,incorporated_date,
#   registered_agent_name,registered_agent_address,filing_url
# GLEIF REST API is free with no key required (https://api.gleif.org/api/v1/)
SOS_DATA_DIR=./data/sos

# ─── Layer 4: Contact Enrichment ──────────────────────────────────────────
# Proxycurl — primary contact enrichment (~$0.02/record)
# https://nubela.co/proxycurl/
PROXYCURL_API_KEY=your_proxycurl_key_here

# Hunter.io — fallback email finder (~$0.01/email)
# https://hunter.io/api
HUNTER_API_KEY=your_hunter_key_here

# ─── Layer 1: Parcel Data (optional paid supplement) ──────────────────────
# ATTOM Data — one-time bulk ingest, not per-query
# https://api.attomdata.com/
ATTOM_API_KEY=your_attom_key_here

# ─── Parcel Ingestion Settings ────────────────────────────────────────────
# Directory for OpenAddresses bulk download files (GeoJSON/CSV)
OPENADDRESSES_DATA_DIR=./data/openaddresses

# Corridor spatial search radius in meters (default: 400)
CORRIDOR_SEARCH_RADIUS_METERS=400

# ─── Context Protocol Marketplace ─────────────────────────────────────────
# Uncomment after onboarding to the Context Protocol marketplace
# CONTEXT_API_KEY=your_context_protocol_key_here

